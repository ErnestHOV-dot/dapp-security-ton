{
  "contractName": "TestGasContract",
  "description": "Scenarios for gas profiling of TestGasContract",
  "defaults": {
    "value": "10000000",
    "senderName": "deployer"
  },
  "initArgs": [
    "deployer"
  ],
  "scenarios": [
    {
      "name": "deploy",
      "kind": "deploy"
    },
    {
      "name": "empty receive",
      "kind": "receive-empty",
      "value": "10000000"
    },
    {
      "name": "deposit text",
      "kind": "receive-text",
      "text": "deposit",
      "value": "20000000"
    },
    {
      "name": "typed add points",
      "kind": "receive-typed",
      "typedMessage": {
        "$$type": "AddPoints",
        "amount": "5"
      },
      "value": "10000000"
    },
    {
      "name": "getter getPoints",
      "kind": "getter",
      "methodName": "getPoints",
      "args": []
    },
    {
      "name": "getter getDepositsCount",
      "kind": "getter",
      "methodName": "getDepositsCount",
      "args": []
    },
    {
      "name": "getter getLastText",
      "kind": "getter",
      "methodName": "getLastText",
      "args": []
    }
  ]
}
