{
  "name": "dapp-security-ton",
  "version": "1.0.0",
  "description": "CLI toolkit for static analysis and gas profiling of TON Tact smart contracts",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "analyze": "ts-node src/index.ts",
    "gas:profile": "ts-node scripts/run-gas-profiler.ts",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','build','reports']) fs.rmSync(p,{recursive:true,force:true});\"",
    "tact:build": "tact --config tact.config.json",
    "test": "node --test -r ts-node/register tests/*.test.ts tests/**/*.test.ts",
    "predeploy:testnet": "npm run tact:build",
    "deploy:testnet": "ts-node scripts/deploy-testnet.ts",
    "wallet:address": "ts-node scripts/get-wallet-address.ts"
  },
  "keywords": [
    "ton",
    "tact",
    "security",
    "static-analysis",
    "gas-profiler"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tact-lang/compiler": "^1.6.13",
    "@ton/core": "^0.60.1",
    "@ton/crypto": "^3.3.0",
    "@ton/sandbox": "^0.31.0",
    "@ton/ton": "^13.9.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
